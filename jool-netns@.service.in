[Unit]
Description=Jool instance inside a dedicated network namespace (%i)
Documentation=https://nicmx.github.io/Jool/en/documentation.html
After=network.target
ConditionPathExists=@sysconfdir@/jool-netns/%i.env

[Service]
Type=oneshot
RemainAfterExit=yes

EnvironmentFile=@sysconfdir@/jool-netns/%i.env
ExecStart=@libexecdir@/up.sh %i
ExecStop=@libexecdir@/down.sh %i

CapabilityBoundingSet=CAP_SYS_ADMIN CAP_SYS_MODULE CAP_NET_ADMIN
NoNewPrivileges=yes
ProtectKernelModules=no
LockPersonality=yes
MemoryDenyWriteExecute=yes
RestrictRealtime=yes
SystemCallArchitectures=native

[Install]
WantedBy=multi-user.target
