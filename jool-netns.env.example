# Copy to /etc/jool-netns/<instance>.env

# Translator mode inside the namespace: nat64 or siit
JOOL_MODE=nat64

# Standard Jool JSON config consumed by "jool file handle" or
# "jool_siit file handle". The file itself must define the Jool instance name
# and framework.
JOOL_CONFIG=/etc/jool/jool.conf

# Optional overrides. The defaults below are safe to reuse across multiple
# instances because each instance gets a dedicated namespace and veth pair.
# NETNS_NAME=jool-example
# HOST_VETH=jool1234567890
# NS_VETH=veth0
# HOST_IPV4=169.254.64.1
# NS_IPV4=169.254.64.2
# HOST_IPV6=fe80::64:1/64
# NS_IPV6=fe80::64:2/64

# Optional host routes toward the namespace translator.
# For host-originated NAT64 tests, HOST_ROUTE6 is usually the pool6 prefix and
# HOST_ROUTE4 is usually the pool4 prefix or address range from the Jool config.
# HOST_ROUTE4=192.168.255.8/32
# HOST_ROUTE6=64:ff9b::/96

# Optional host-side masquerade for traffic leaving the namespace through the
# host. Disabled by default.
# HOST_MASQUERADE=1

# Optional host forwarding knobs. Disabled by default.
# HOST_IPV4_FORWARD=1
# HOST_IPV6_FORWARD=1

# Optional: deterministic nftables table name used for the host-side NAT rule.
# JOOL_NFT_TABLE=jool_netns_1234567890
